{
  "name": "metriq-api-postgres",
  "version": "1.0.0",
  "description": "Backend API for MetriQ — PostgreSQL + Prisma + TypeScript",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio"
  },
  "keywords": [
    "metrics",
    "performance",
    "audit",
    "web performance",
    "pagespeed",
    "google lighthouse",
    "comparison",
    "AI summary",
    "MERN stack",
    "metriq"
  ],
  "author": "Tracey Kadenyi",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "axios": "^1.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "prisma": "^5.22.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.0"
  }
}
